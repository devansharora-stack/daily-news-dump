{
  "name": "daily-updates",
  "version": "1.0.0",
  "description": "AI Content Intelligence Pipeline — automated daily digest of AI + business stories",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "fetch": "node src/index.js --step=fetch",
    "curate": "node src/index.js --step=curate",
    "publish": "node src/index.js --step=publish",
    "dry-run": "node src/index.js --dry-run",
    "b2b": "node src/b2b-index.js",
    "b2b:fetch": "node src/b2b-index.js --step=fetch",
    "b2b:select": "node src/b2b-index.js --step=select",
    "b2b:publish": "node src/b2b-index.js --step=publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "p-limit": "^6.2.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.0.0",
    "rss-parser": "^3.13.0",
    "winston": "^3.17.0"
  }
